        <item>\u00e7</item>  <!-- ç -->
        <item>\u00e0</item>  <!-- à -->
        <item>\u00b0</item>  <!-- ° -->
    </string-array>
    <string-array name="keymap_fr_shift">
        <item>A</item>
        <item>Z</item>
        <item>E</item>
        <item>R</item>
        <item>T</item>
