<?xml version="1.0" encoding="utf-8"?>
<!--
    XKB-style key symbol naming conventions for locale-specific keymaps.

    This file maps logical key positions to their symbol names for each
    supported locale. When a locale-specific layout is loaded from
    res/xml-{locale}/, the loader consults this mapping to resolve
    the correct label and code for each key based on its XKB symbol name.

    Symbol names follow the pattern: <group><level>
    - group: base, shift, altgr, shift_altgr
    - level: 1 (unshifted), 2 (shifted), 3 (AltGr), 4 (shift+AltGr)

    Example: "adiaeresis" = ä, "Adiaeresis" = Ä (shifted)
-->
<resources>
    <!--
        Key symbol definitions per locale. Each locale maps XKB symbol names
        to the Unicode characters or keycodes that should be produced.

        For the base English layout, symbols map directly to ASCII.
        Locale-specific overrides replace keys at the same logical position.
    -->

    <!-- German (de) overrides for the base QWERTZ layout -->
    <string-array name="keymap_de_base">
        <item>y</item>  <!-- y ↔ z swap for QWERTZ -->
        <item>z</item>
        <item>ü</item>
        <item>ä</item>
        <item>ö</item>
        <item>ß</item>
        <item>#</item>
        <item>\u00e4</item>  <!-- ä -->
        <item>\u00f6</item>  <!-- ö -->
        <item>\u00fc</item>  <!-- ü -->
        <item>\u00df</item>  <!-- ß -->
    </string-array>
    <string-array name="keymap_de_shift">
        <item>Y</item>
        <item>Z</item>
        <item>Ü</item>
        <item>Ä</item>
        <item>Ö</item>
        <item>SS</item>
        <item>\u00b0</item>  <!-- ° -->
        <item>\u00c4</item>  <!-- Ä -->
        <item>\u00d6</item>  <!-- Ö -->
        <item>\u00dc</item>  <!-- Ü -->
    </string-array>

    <!-- French (fr) AZERTY overrides -->
