<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:app="http://schemas.android.com/apk/res-auto"
    app:keyWidth="10%p"
    app:keyHeight="10%p">
    <Row app:isExtension="true">
        <Key app:codes="-111" app:label="Esc" />
        <Key app:codes="-131" app:label="F1" />
        <Key app:codes="-132" app:label="F2" />
        <Key app:codes="-133" app:label="F3" />
        <Key app:codes="-134" app:label="F4" />
        <Key app:codes="-135" app:label="F5" />
        <Key app:codes="-136" app:label="F6" />
