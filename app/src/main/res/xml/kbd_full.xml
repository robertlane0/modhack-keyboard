    <Row>
        <Key app:codes="9" app:label="Tab" app:keyWidth="10%p" />
        <Key app:codes="-113" app:label="Ctrl" app:isModifier="true" app:keyWidth="10%p" />
        <Key app:codes="-57" app:label="Alt" app:isModifier="true" app:keyWidth="10%p" />
        <Key app:codes="-2" app:label="@string/label_symbols" app:keyWidth="10%p" />
        <Key app:codes="32" app:label="" app:keyWidth="30%p" />
        <Key app:codes="-21" app:label="Left" app:isRepeatable="true" app:isCursor="true" app:keyWidth="7.5%p" />
